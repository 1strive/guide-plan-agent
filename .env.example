# 若本机 3000 已被占用（如其他服务），可改为 3001
PORT=3001
MYSQL_HOST=127.0.0.1
# 使用仓库内 docker-compose 时映射为 3307，避免与主机已有 MySQL(3306) 冲突
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=test
MYSQL_DATABASE=guide_plan

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHAT_HISTORY_LIMIT=30
RAG_TOP_K_DEFAULT=8
RAG_CANDIDATE_LIMIT=2000
LLM_MAX_TOOL_ROUNDS=10

# LLM 推理参数 (0.0~2.0, 值越高输出越随机)
LLM_TEMPERATURE=0.4
